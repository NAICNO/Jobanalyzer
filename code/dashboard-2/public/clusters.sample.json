        "userInfo": "https://keycloak.example.no/realms/my-realm/protocol/openid-connect/userinfo",
        "clientId": "my-client-id",
        "scope": "openid profile email"
      },
      "requiresAuth": true
    },
    {
      "id": "cluster-b.example.no",
      "name": "Example Cluster B",
      "shortName": "Cluster B",
      "description": "HPC cluster without authentication",
      "icon": "LuServer",
      "apiBaseUrl": "https://cluster-b.example.no/api/v2",
      "requiresAuth": false
    }
  ]
